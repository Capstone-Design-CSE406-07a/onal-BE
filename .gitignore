# 의존성 라이브러리 (용량이 크고 npm install로 언제든 재생성 가능)
node_modules/

# 환경 변수 파일 (비밀번호, DB URI 등이 들어있으므로 절대 올리면 안 됨)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 빌드 결과물 (TypeScript 컴파일 결과 등)
dist/
build/
out/

# 로그 파일
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS 설정 파일
.DS_Store
Thumbs.db

# 에디터 설정
.vscode/
.idea/